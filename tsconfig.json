{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2022"],
    "strict": false,
    "noEmitOnError": false,
    "rootDir": "./src",
    "outDir": "./assets/scripts",
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
